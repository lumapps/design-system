{
    "license": "MIT",
    "name": "@lumx/vue",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/lumapps/design-system.git"
    },
    "scripts": {
        "lint": "cd ../.. && eslint packages/lumx-vue/src/ --ext .ts,.tsx,.vue",
        "build": "vite build",
        "type-check": "vue-tsc",
        "start:storybook": "storybook dev -p 9001",
        "build:storybook": "storybook build",
        "test": "vitest run --run",
        "test:storybook": "vitest -c .storybook/vitest.config.mts run --run",
        "test:storybook:visual": "IMAGE_SNAPSHOT=true SNAPSHOT_ONLY=true vitest -c .storybook/vitest.config.mts run --run"
    },
    "type": "module",
    "module": "index.js",
    "main": "index.js",
    "types": "index.d.ts",
    "exports": {
        ".": {
            "types": "./index.d.ts",
            "default": "./index.js"
        },
        "./utils": {
            "types": "./utils/index.d.ts",
            "default": "./utils/index.js"
        }
    },
    "sideEffects": false,
    "version": "4.17.0",
    "dependencies": {
        "@floating-ui/vue": "^1.1.10",
        "@lumx/core": "^4.17.0",
        "@lumx/icons": "^4.17.0",
        "@vueuse/core": "^14.1.0"
    },
    "peerDependencies": {
        "lodash": "4.17.21",
        "vue": "^3.5.27"
    },
    "devDependencies": {
        "@babel/plugin-transform-react-jsx": "7.28.6",
        "@lumx/base-vite-lib-config": "workspace:*",
        "@lumx/storybook-testing": "workspace:*",
        "@storybook/addon-a11y": "^10.2.19",
        "@storybook/vue3-vite": "^10.2.19",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/user-event": "^14.4.3",
        "@testing-library/vue": "^8.1.0",
        "@types/lodash": "^4.14.149",
        "@vitejs/plugin-vue": "^6.0.3",
        "@vitejs/plugin-vue-jsx": "^5.1.3",
        "@vue/test-utils": "^2.4.6",
        "chromatic": "^13.3.5",
        "focus-visible": "^5.2.1",
        "jsdom": "^27.2.0",
        "storybook": "^10.2.19",
        "typescript": "^5.4.3",
        "vite": "^8.0.16",
        "vitest": "^4.1.9",
        "vue": "^3.5.27",
        "vue-tsc": "^3.2.4"
    }
}
