{
    "author": {
        "name": "LumApps"
    },
    "bugs": {
        "url": "https://github.com/lumapps/design-system/issues"
    },
    "dependencies": {
        "@floating-ui/react-dom": "^2.1.7",
        "@lumx/core": "^4.17.0",
        "@lumx/icons": "^4.17.0",
        "body-scroll-lock": "^3.1.5"
    },
    "devDependencies": {
        "@lumx/storybook-testing": "workspace:*",
        "@storybook/addon-a11y": "^10.2.19",
        "@storybook/react-vite": "^10.2.19",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.1",
        "@testing-library/user-event": "^14.6.1",
        "@types/body-scroll-lock": "^2.6.1",
        "@types/classnames": "^2.2.9",
        "@types/dom-view-transitions": "^1.0.5",
        "@types/lodash": "^4.14.149",
        "@types/react": "^18.3.24",
        "@types/react-dom": "^18.3.7",
        "@vitest/ui": "^4.1.9",
        "autoprefixer": "^9.7.4",
        "chromatic": "^13.1.4",
        "focus-visible": "^5.0.2",
        "glob": "^7.1.6",
        "jsdom": "^27.2.0",
        "lodash": "4.18.1",
        "playwright": "^1.58.2",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "storybook": "^10.2.19",
        "typescript": "^5.4.3",
        "vite": "^8.0.16",
        "vite-plugin-dts": "^5.0.2",
        "vite-plugin-static-copy": "^4.1.1",
        "vitest": "^4.1.9"
    },
    "peerDependencies": {
        "lodash": ">= 4.17.23",
        "react": ">= 17.0.2",
        "react-dom": ">= 17.0.2"
    },
    "description": "The official LumApps Design System (LumX) for React applications",
    "homepage": "https://github.com/lumapps/design-system",
    "keywords": [
        "Design System",
        "LumApps",
        "LumX",
        "React"
    ],
    "license": "MIT",
    "type": "module",
    "module": "index.js",
    "main": "index.js",
    "types": "index.d.ts",
    "name": "@lumx/react",
    "exports": {
        ".": {
            "types": "./index.d.ts",
            "default": "./index.js"
        },
        "./utils": {
            "types": "./utils/index.d.ts",
            "default": "./utils/index.js"
        }
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/lumapps/design-system.git"
    },
    "scripts": {
        "lint": "cd ../.. && eslint packages/lumx-react/src/",
        "build": "vite build",
        "test": "vitest run --run",
        "test:storybook": "vitest -c .storybook/vitest.config.mts run --run",
        "test:storybook:visual": "IMAGE_SNAPSHOT=true SNAPSHOT_ONLY=true vitest -c .storybook/vitest.config.mts run --run",
        "type-check": "yarn tsc -p tsconfig.json",
        "start:storybook": "storybook dev -p 9000",
        "build:storybook": "storybook build"
    },
    "sideEffects": false,
    "version": "4.17.0"
}
